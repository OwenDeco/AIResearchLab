# ============================================================
# AI Retrieval & Benchmark Lab — environment configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
# OpenAI (required for GPT models and OpenAI embeddings)
# ----------------------------------------------------------
OPENAI_API_KEY=YOUR_OPENAI_API_KEY_HERE

# ----------------------------------------------------------
# Azure OpenAI (optional — leave blank to skip)
# ----------------------------------------------------------
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01   # not configurable via UI

# ----------------------------------------------------------
# Local Ollama (optional — default assumes localhost)
# ----------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ----------------------------------------------------------
# Graph store
# ----------------------------------------------------------
# Leave NEO4J_URI blank to use the built-in NetworkX store.
# Set it to use Neo4j instead.
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# ----------------------------------------------------------
# Database & storage paths
# ----------------------------------------------------------
DATABASE_URL=sqlite:///./ragtool.db
CHROMA_PERSIST_DIR=./chroma_data
GRAPH_DATA_PATH=./graph_data.json

# ----------------------------------------------------------
# Application defaults
# ----------------------------------------------------------
DEFAULT_LLM=openai/gpt-4o-mini
DEFAULT_EMBED_MODEL=openai/text-embedding-3-small

# ----------------------------------------------------------
# Server
# ----------------------------------------------------------
HOST=0.0.0.0
PORT=8002

# Public base URL written into the A2A Agent Card.
# Override with your ngrok URL or production domain when exposing externally.
AGENT_BASE_URL=http://localhost:8002

# ----------------------------------------------------------
# Debug (set to true to enable verbose MCP request/response logging)
# ----------------------------------------------------------
DEBUG=false
